# i32 main()
{
    i32 a = 5;
    i32 b = 3;
    i32 c = 2;
    i32 d = 4;

    i32 x1 = a + b * c - d;
    i32 x2 = (a + b) * (c - d);
    i32 x3 = !(a == 5) + (b == 3);
    i32 x4 = (c * d == 8) + (a / b == 1);
    i32 x5 = !((a + b) == (c * d)) + (d - c == 2);

    i32 x6 = (x1 == 7) + (x2 == -8);
    i32 x7 = (x3 + x4) * (x5 + 1);

    i32 x8 = !(x7 == 0) + (x6 == 2);
    i32 x9 = (x8 + x7) - (x4 * x3);

    i32 result = x1 + x2 + x3 + x4 + x5 + x6 + x7 + x8 + x9;

    return result;
}
