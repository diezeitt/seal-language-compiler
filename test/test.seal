#
i32 main()
{
    i32 a = 13;
    i32 b = 5;
    i32 c = 2;
    i32 d = 8;
    i32 e = 3;

    i32 x1 =
        a + b * c - d / e;

    i32 x2 =
        ((a - b) * (d + c))
        /
        (e + 1);

    i32 x3 =
        (a / b) +
        (d / c) *
        (e + b);

    i32 x4 =
        !(x1 == x2);

    i32 x5 =
        !!(x3 - x1);

    i32 x6 =
        (x1 == x2) ==
        (x4 == x5);

    i32 x7 =
        !(a - a) +
        !(b - 5) +
        !(c - 3);

    i32 x8 =
        (
            (x4 + x5)
            *
            (x6 + 1)
        )
        +
        (
            x7 == 2
        );

    i32 x9 =
        (
            (
                a + b * c
            )
            ==
            (
                d + e * b
            )
        )
        ==
        (
            x1 > x2
        );

    i32 x10 =
        (
            (
                x8 + x9
            )
            *
            (
                !x6 + 1
            )
        )
        -
        (
            x3 / (c + 1)
        );

    i32 x11 =
        !!(
            x10 +
            x9 -
            x8 +
            x7
        );

    i32 x12 =
        (
            (
                (
                    x1 + x2
                )
                ==
                (
                    x3 - x4
                )
            )
            +
            (
                (
                    x5 + x6
                )
                ==
                (
                    x7 + x8
                )
            )
        );

    i32 result =
        x1 +
        x2 +
        x3 +
        x4 +
        x5 +
        x6 +
        x7 +
        x8 +
        x9 +
        x10 +
        x11 +
        x12;

    return result;
}
